generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model chat_messages {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @db.Uuid
  sender          String   @db.VarChar(20)
  message         String
  conversation_id String?  @db.Uuid
  metadata        Json?
  created_at      DateTime @default(now()) @db.Timestamp(6)
  users           users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversation_id, created_at], map: "chat_messages_conversation_time_idx")
  @@index([user_id, created_at], map: "chat_messages_user_time_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model instruments {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String        @db.VarChar(120)
  type             String        @db.VarChar(50)
  description      String
  image_url        String
  audio_sample_url String?
  is_vip           Boolean       @default(false)
  tags             String[]      @default([])
  status           String        @default("active") @db.VarChar(20)
  created_at       DateTime      @default(now()) @db.Timestamp(6)
  updated_at       DateTime      @default(now()) @db.Timestamp(6)
  media_items      media_items[]

  @@index([status, is_vip, type], map: "instruments_status_vip_type_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model media_items {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String      @db.Uuid
  instrument_id    String      @db.Uuid
  type             String      @db.VarChar(20)
  title            String      @db.VarChar(200)
  source_url       String?
  youtube_video_id String?     @db.VarChar(50)
  file_url         String?
  duration_seconds Int?
  created_at       DateTime    @default(now()) @db.Timestamp(6)
  updated_at       DateTime    @default(now()) @db.Timestamp(6)
  instruments      instruments @relation(fields: [instrument_id], references: [id], onUpdate: NoAction)
  users            users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([instrument_id, created_at(sort: Desc)], map: "media_items_instrument_recent_idx")
  @@index([user_id, created_at(sort: Desc)], map: "media_items_user_recent_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payments {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  plan_id        String    @db.Uuid
  amount         Int
  currency       String    @default("VND") @db.VarChar(10)
  provider       String    @db.VarChar(30)
  status         String    @default("pending") @db.VarChar(20)
  transaction_id String    @db.VarChar(200)
  raw_response   Json?
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  updated_at     DateTime  @default(now()) @db.Timestamp(6)
  vip_plans      vip_plans @relation(fields: [plan_id], references: [id], onUpdate: NoAction)
  users          users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider, transaction_id], map: "payments_provider_transaction_unique")
  @@index([user_id, created_at(sort: Desc)], map: "payments_user_recent_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model subscriptions {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  plan_id      String    @db.Uuid
  status       String    @default("pending") @db.VarChar(20)
  started_at   DateTime  @db.Timestamp(6)
  expired_at   DateTime  @db.Timestamp(6)
  cancelled_at DateTime? @db.Timestamp(6)
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  updated_at   DateTime  @default(now()) @db.Timestamp(6)
  vip_plans    vip_plans @relation(fields: [plan_id], references: [id], onUpdate: NoAction)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, status, expired_at(sort: Desc)], map: "subscriptions_user_status_expired_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name     String          @db.VarChar(100)
  email         String          @unique @db.VarChar(255)
  password_hash String
  avatar_url    String?
  phone         String?         @db.VarChar(30)
  role          String          @default("user") @db.VarChar(20)
  status        String          @default("active") @db.VarChar(20)
  created_at    DateTime        @default(now()) @db.Timestamp(6)
  updated_at    DateTime        @default(now()) @db.Timestamp(6)
  chat_messages chat_messages[]
  media_items   media_items[]
  payments      payments[]
  subscriptions subscriptions[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model vip_plans {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String          @unique @db.VarChar(50)
  name          String          @db.VarChar(100)
  description   String?
  price         Int
  currency      String          @default("VND") @db.VarChar(10)
  duration_days Int
  features      String[]        @default([])
  status        String          @default("active") @db.VarChar(20)
  created_at    DateTime        @default(now()) @db.Timestamp(6)
  updated_at    DateTime        @default(now()) @db.Timestamp(6)
  payments      payments[]
  subscriptions subscriptions[]

  @@index([status, price])
}
